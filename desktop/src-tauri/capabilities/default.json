{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "SpecRelay desktop launcher capability",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "allow-configure-database",
    "allow-minimize-window",
    "allow-toggle-maximize-window",
    "allow-close-window"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:*"
    ]
  }
}
