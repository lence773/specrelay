{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrelay.local/schemas/plan-spec-v2.json",
  "title": "SpecRelay PlanSpec v2",
  "description": "Canonical versioned PlanSpec. compatibilityMode marks plans upgraded from the legacy unversioned view.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "compatibilityMode",
    "title",
    "summary",
    "tasks",
    "finalValidation"
  ],
  "properties": {
    "version": {"const": 2},
    "compatibilityMode": {"type": "boolean"},
    "title": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "tasks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {"$ref": "#/$defs/task"}
    },
    "finalValidation": {"$ref": "#/$defs/validationDefinition"}
  },
  "allOf": [
    {
      "if": {
        "properties": {"compatibilityMode": {"const": false}},
        "required": ["compatibilityMode"]
      },
      "then": {
        "properties": {
          "finalValidation": {
            "type": "object",
            "properties": {
              "commands": {"minItems": 1}
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "key": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Z0-9]+(?:-[A-Z0-9]+)*$"
    },
    "stringList": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "acceptanceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "description"],
      "properties": {
        "key": {"$ref": "#/$defs/key"},
        "description": {"type": "string", "minLength": 1}
      }
    },
    "acceptanceList": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/acceptanceItem"}
    },
    "validationDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptance", "commands"],
      "properties": {
        "acceptance": {"$ref": "#/$defs/acceptanceList"},
        "commands": {"$ref": "#/$defs/stringList"}
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "title",
        "dependsOn",
        "scope",
        "inputs",
        "outputs",
        "risks",
        "acceptance",
        "validationCommands"
      ],
      "properties": {
        "key": {"$ref": "#/$defs/key"},
        "title": {"type": "string", "minLength": 1},
        "dependsOn": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/key"}
        },
        "scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "inputs": {"$ref": "#/$defs/stringList"},
        "outputs": {"$ref": "#/$defs/stringList"},
        "risks": {"$ref": "#/$defs/stringList"},
        "acceptance": {"$ref": "#/$defs/acceptanceList"},
        "validationCommands": {"$ref": "#/$defs/stringList"}
      }
    }
  }
}
